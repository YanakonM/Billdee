{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Billdee",
  "version": "0.1.1",
  "identifier": "com.texv2.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Billdee — ระบบใบกำกับภาษี",
        "width": 1280,
        "height": 832,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YanakonM/Billdee/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMDMzREZEMUIwMTJGNzQKUldSMEx3RWIvVDBEU3VIeklXMU1OUThqcTlRdDFTRFdlU1k3NDI5MVVGNEgybWJQNzVnVnhkM2UK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
